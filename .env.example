# API Keys
SERPER_API_KEY=your_serper_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GITHUB_API_KEY=your_github_key_here

# Google Sheets Configuration
# Get GOOGLE_SHEET_ID by running: python setup_sheets.py
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Affiliate programs (optional) — leave blank to use plain product URLs
# AMAZON_AFFILIATE_TAG=yourtag-20

# Telegram alerts (optional) — get token from @BotFather, chat_id from @userinfobot
# TELEGRAM_BOT_TOKEN=123456789:AAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# TELEGRAM_CHAT_ID=987654321

# Browser dashboard (public/index.html + public/latest.json). Disable with MEH_DASHBOARD=0.
# MEH_DASHBOARD_DRY_RUN=1 logs intent without writing files.
# For GitHub project Pages, CI sets MEH_DASHBOARD_BASE_PATH=/repo-name/ so links resolve under /repo-name/.
# MEH_DASHBOARD=1
# MEH_DASHBOARD_DRY_RUN=0
# MEH_DASHBOARD_BASE_PATH=
